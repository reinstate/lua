-- Structure: ItemSpawners > BasePart (Celestial, Common, Op, etc.) > Model (SpawnedItem)
-- Features: 3 separate clean GUIs, bulletproof following, continuous farming

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = nil
local humanoidRootPart = nil
local humanoid = nil

-- Update character references
local function updateCharacter()
    character = player.Character
    if character then
        humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
        humanoid = character:FindFirstChild("Humanoid")
    end
end
updateCharacter()

player.CharacterAdded:Connect(function(char)
    character = char
    humanoidRootPart = char:FindFirstChild("HumanoidRootPart")
    humanoid = char:FindFirstChild("Humanoid")
end)

player.CharacterRemoving:Connect(function()
    character = nil
    humanoidRootPart = nil
    humanoid = nil
end)

-- ===== CONFIGURATION =====
local WAIT_TIME = 0.3
local HOLD_DURATION = 0.2
local PICKUP_DELAY = 0.1
local FOLLOW_DISTANCE = 0.5
local FOLLOW_SPEED = 0.05
local LOOP_DELAY = 0.3

-- ===== GET STRUCTURES =====
local itemSpawners = workspace:FindFirstChild("ItemSpawners")
local plotsFolder = workspace:FindFirstChild("Plots")

-- Get all item parts (BaseParts inside ItemSpawners - INCLUDING Op)
local itemParts = {}
if itemSpawners then
    for _, child in ipairs(itemSpawners:GetChildren()) do
        -- Check if it's a BasePart
        if child:IsA("BasePart") then
            table.insert(itemParts, child)
        end
    end
    -- Sort by name
    table.sort(itemParts, function(a, b) return a.Name < b.Name end)
end

-- Debug print
print("✅ Found item parts:")
for _, part in ipairs(itemParts) do
    print("  • " .. part.Name)
end

local plotParts = {}
if plotsFolder then
    for _, child in ipairs(plotsFolder:GetChildren()) do
        if child:IsA("BasePart") then
            table.insert(plotParts, child)
        end
    end
end

-- ===== TELEPORT FUNCTIONS =====
local function teleportTo(position)
    if not humanoidRootPart then return end
    humanoidRootPart.CFrame = CFrame.new(position)
end

local function teleportToPlot()
    if not humanoidRootPart then return end
    if #plotParts > 0 then
        local randomPlot = plotParts[math.random(1, #plotParts)]
        if randomPlot then
            teleportTo(Vector3.new(randomPlot.Position.X, randomPlot.Position.Y + 3, randomPlot.Position.Z))
            return true
        end
    end
    local currentPos = humanoidRootPart.Position
    teleportTo(Vector3.new(currentPos.X, currentPos.Y - 10, currentPos.Z))
    return false
end

local function teleportToItem(itemPart)
    if not humanoidRootPart or not itemPart then return end
    teleportTo(Vector3.new(itemPart.Position.X, itemPart.Position.Y + 1, itemPart.Position.Z))
end

-- ===== ITEM PICKUP FUNCTIONS =====
-- Gets all SpawnedItem models inside a BasePart
local function getSpawnedItemsFromPart(part)
    local items = {}
    if not part then return items end
    
    for _, child in ipairs(part:GetChildren()) do
        if child:IsA("Model") and child.Name == "SpawnedItem" then
            table.insert(items, child)
        end
    end
    return items
end

-- Gets a clickable part from a SpawnedItem model
local function getClickablePart(model)
    for _, child in ipairs(model:GetChildren()) do
        if child:IsA("BasePart") then
            return child
        end
    end
    return model.PrimaryPart or nil
end

-- Pick up an item - KEEPS PRESSING E
local function pickUpItem(itemPart)
    if not itemPart or not humanoidRootPart then return false end
    
    teleportToItem(itemPart)
    wait(0.05)
    
    -- Method 1: Try clicking
    local clicked = false
    pcall(function()
        local screenPoint, onScreen = workspace.CurrentCamera:WorldToScreenPoint(itemPart.Position)
        if onScreen then
            local screenPos = Vector2.new(screenPoint.X, screenPoint.Y)
            VirtualInputManager:SendMouseMove(screenPos, 0)
            wait(0.03)
            VirtualInputManager:SendMouseButtonEvent(Enum.UserInputType.MouseButton1, 0, true, screenPos, 0)
            wait(HOLD_DURATION)
            VirtualInputManager:SendMouseButtonEvent(Enum.UserInputType.MouseButton1, 0, false, screenPos, 0)
            clicked = true
        end
    end)
    
    -- Method 2: ALWAYS press E (multiple times to ensure pickup)
    for i = 1, 3 do
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, nil)
        wait(0.05)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, nil)
        wait(0.05)
    end
    
    -- Hold E for a bit longer to ensure pickup
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, nil)
    wait(HOLD_DURATION)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, nil)
    
    wait(PICKUP_DELAY)
    return true
end

-- ===== BULLETPROOF FOLLOWER =====
local followTarget = nil
local isFollowing = false
local followCoroutine = nil

local function getTargetRoot()
    if not followTarget then return nil end
    local targetChar = followTarget.Character
    if not targetChar then return nil end
    local targetHumanoid = targetChar:FindFirstChild("Humanoid")
    if targetHumanoid and targetHumanoid.Health <= 0 then
        return nil
    end
    return targetChar:FindFirstChild("HumanoidRootPart")
end

local function followPlayer()
    if not humanoidRootPart then return false end
    
    local targetRoot = getTargetRoot()
    if not targetRoot then return false end
    
    local targetPos = targetRoot.Position
    local followPos = Vector3.new(
        targetPos.X + (math.random(-1, 1) * 0.3),
        targetPos.Y + 0.5,
        targetPos.Z + (math.random(-1, 1) * 0.3)
    )
    
    teleportTo(followPos)
    return true
end

local function startFollowing()
    if not followTarget then
        return false, "Select a player first!"
    end
    if isFollowing then return true, "Already following" end
    
    isFollowing = true
    followCoroutine = coroutine.create(function()
        while isFollowing do
            if not humanoidRootPart then
                updateCharacter()
                wait(0.5)
                continue
            end
            
            local success = followPlayer()
            if not success then
                wait(0.2)
            else
                wait(FOLLOW_SPEED)
            end
            
            if followTarget and not followTarget.Character then
                wait(1)
            end
        end
    end)
    coroutine.resume(followCoroutine)
    return true, "Following " .. followTarget.Name
end

local function stopFollowing()
    isFollowing = false
    if followCoroutine then
        coroutine.close(followCoroutine)
        followCoroutine = nil
    end
    return true, "Stopped following"
end

-- ===== CREATE SEPARATE GUIS =====

-- Function to make any frame draggable
local function makeDraggable(frame)
    local dragging = false
    local dragStart, startPos
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    frame.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
                                      startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

