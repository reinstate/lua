    screenGui.ResetOnSpawn = false
    
    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 200, 0, 60)
    mainFrame.Position = UDim2.new(0.68, 0, 0.1, 0)
    mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    mainFrame.BackgroundTransparency = 0.05
    mainFrame.BorderSizePixel = 2
    mainFrame.BorderColor3 = Color3.fromRGB(255, 50, 50)
    mainFrame.Parent = screenGui
    makeDraggable(mainFrame)
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0.35, 0)
    title.Position = UDim2.new(0, 0, 0, 0)
    title.Text = "🛑 Emergency Stop"
    title.TextColor3 = Color3.fromRGB(255, 50, 50)
    title.BackgroundTransparency = 1
    title.Font = Enum.Font.GothamBold
    title.TextSize = 14
    title.Parent = mainFrame
    
    local stopBtn = Instance.new("TextButton")
    stopBtn.Size = UDim2.new(0.9, 0, 0.50, 0)
    stopBtn.Position = UDim2.new(0.05, 0, 0.40, 0)
    stopBtn.Text = "🛑 STOP EVERYTHING"
    stopBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    stopBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    stopBtn.BackgroundTransparency = 0.15
    stopBtn.BorderSizePixel = 2
    stopBtn.BorderColor3 = Color3.fromRGB(150, 0, 0)
    stopBtn.Font = Enum.Font.GothamBold
    stopBtn.TextSize = 13
    stopBtn.Parent = mainFrame
    
    stopBtn.MouseButton1Click:Connect(function()
        -- Stop farming
        if isFarming then
            isFarming = false
            if farmCoroutine then
                coroutine.close(farmCoroutine)
                farmCoroutine = nil
            end
            local farmGUI = player.PlayerGui:FindFirstChild("FarmGUI")
            if farmGUI then
                local btn = farmGUI:FindFirstChildWhichIsA("TextButton")
                if btn then
                    btn.Text = "▶ Start Farming"
                    btn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
                    btn.BorderColor3 = Color3.fromRGB(0, 100, 0)
                end
                local status = farmGUI:FindFirstChildWhichIsA("TextLabel")
                if status then
                    status.Text = "⏹ Stopped"
                    status.TextColor3 = Color3.fromRGB(255, 150, 150)
                end
            end
        end
        
        -- Stop following
        if isFollowing then
            stopFollowing()
            local trollGUI = player.PlayerGui:FindFirstChild("TrollGUI")
            if trollGUI then
                local btn = trollGUI:FindFirstChildWhichIsA("TextButton")
                if btn then
                    btn.Text = "▶ Start Trolling"
                    btn.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
                    btn.BorderColor3 = Color3.fromRGB(150, 70, 0)
                end
                local status = trollGUI:FindFirstChildWhichIsA("TextLabel")
                if status then
                    status.Text = "⏹ Stopped"
                    status.TextColor3 = Color3.fromRGB(200, 200, 200)
                end
            end
        end
        
        -- Teleport to plot
        if humanoidRootPart then
            teleportToPlot()
        end
        
        print("🛑 All actions stopped!")
    end)
    
    return screenGui
end

