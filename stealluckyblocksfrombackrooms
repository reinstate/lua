    selectedDisplay.Position = UDim2.new(0, 0, 0, 0)
    selectedDisplay.Text = "Selected: None"
    selectedDisplay.TextColor3 = Color3.fromRGB(200, 200, 200)
    selectedDisplay.BackgroundTransparency = 1
    selectedDisplay.Font = Enum.Font.Gotham
    selectedDisplay.TextSize = 11
    selectedDisplay.TextXAlignment = Enum.TextXAlignment.Left
    selectedDisplay.Parent = controlFrame
    
    -- Status
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(1, -20, 0.05, 0)
    status.Position = UDim2.new(0, 10, 0.74, 0)
    status.Text = "⏹ Not trolling"
    status.TextColor3 = Color3.fromRGB(200, 200, 200)
    status.BackgroundTransparency = 1
    status.Font = Enum.Font.Gotham
    status.TextSize = 11
    status.TextXAlignment = Enum.TextXAlignment.Left
    status.Parent = mainFrame
    
    local trollBtn = Instance.new("TextButton")
    trollBtn.Size = UDim2.new(0.9, 0, 0.10, 0)
    trollBtn.Position = UDim2.new(0.05, 0, 0.80, 0)
    trollBtn.Text = "▶ Start Trolling"
    trollBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    trollBtn.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
    trollBtn.BackgroundTransparency = 0.15
    trollBtn.BorderSizePixel = 2
    trollBtn.BorderColor3 = Color3.fromRGB(150, 70, 0)
    trollBtn.Font = Enum.Font.GothamBold
    trollBtn.TextSize = 13
    trollBtn.Parent = mainFrame
    
    -- Player list functions
    local playerButtons = {}
    
    local function refreshPlayerList()
        for _, child in ipairs(playerScroll:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        playerButtons = {}
        
        local players = Players:GetPlayers()
        local yOffset = 0
        
        for _, p in ipairs(players) do
            if p ~= player then
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, -10, 0, 24)
                btn.Position = UDim2.new(0, 5, 0, yOffset)
                btn.Text = p.Name
                btn.TextColor3 = Color3.fromRGB(200, 200, 200)
                btn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
                btn.BackgroundTransparency = 0.2
                btn.BorderSizePixel = 1
                btn.BorderColor3 = Color3.fromRGB(60, 60, 80)
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 11
                btn.TextXAlignment = Enum.TextXAlignment.Left
                btn.Parent = playerScroll
                
                btn.MouseButton1Click:Connect(function()
                    followTarget = p
                    selectedDisplay.Text = "Selected: " .. p.Name
                    for _, b in ipairs(playerButtons) do
                        b.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
                        b.BackgroundTransparency = 0.2
                    end
                    btn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
                    btn.BackgroundTransparency = 0.3
                end)
                
                table.insert(playerButtons, btn)
                yOffset = yOffset + 28
            end
        end
        
        playerScroll.CanvasSize = UDim2.new(0, 0, 0, yOffset + 10)
        
        if yOffset == 0 then
            local noPlayers = Instance.new("TextLabel")
            noPlayers.Size = UDim2.new(1, 0, 1, 0)
            noPlayers.Text = "No other players found"
            noPlayers.TextColor3 = Color3.fromRGB(150, 150, 150)
            noPlayers.BackgroundTransparency = 1
            noPlayers.Font = Enum.Font.Gotham
            noPlayers.TextSize = 12
            noPlayers.Parent = playerScroll
        end
    end
    
    refreshBtn.MouseButton1Click:Connect(function()
        refreshPlayerList()
        refreshBtn.Text = "✅"
        wait(0.5)
        refreshBtn.Text = "🔄"
    end)
    
    -- Auto-refresh
    spawn(function()
        while true do
            wait(3)
            refreshPlayerList()
        end
    end)
    
    trollBtn.MouseButton1Click:Connect(function()
        if isFollowing then
            local _, msg = stopFollowing()
            trollBtn.Text = "▶ Start Trolling"
            trollBtn.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
            trollBtn.BorderColor3 = Color3.fromRGB(150, 70, 0)
            status.Text = "⏹ " .. msg
            status.TextColor3 = Color3.fromRGB(200, 200, 200)
        else
            local success, msg = startFollowing()
            if success then
                trollBtn.Text = "⏹ Stop Trolling"
                trollBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
                trollBtn.BorderColor3 = Color3.fromRGB(150, 0, 0)
                status.Text = "📍 " .. msg
                status.TextColor3 = Color3.fromRGB(150, 255, 150)
            else
                status.Text = "⚠️ " .. msg
                status.TextColor3 = Color3.fromRGB(255, 200, 100)
            end
        end
    end)
    
    refreshPlayerList()
    return screenGui
end

