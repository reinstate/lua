    local function startFarming()
        local hasSelection = false
        for _, selected in pairs(selectedItems) do
            if selected then hasSelection = true; break end
        end
        
        if not hasSelection then
            status.Text = "⚠️ Select at least one item!"
            status.TextColor3 = Color3.fromRGB(255, 200, 100)
            return
        end
        
        if isFarming then return end
        isFarming = true
        totalCollected = 0
        farmBtn.Text = "⏹ Stop"
        farmBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        farmBtn.BorderColor3 = Color3.fromRGB(150, 0, 0)
        status.Text = "⏳ Farming..."
        status.TextColor3 = Color3.fromRGB(255, 255, 150)
        
        farmCoroutine = coroutine.create(function()
            local originalPos = humanoidRootPart and humanoidRootPart.Position
            
            while isFarming do
                if not humanoidRootPart then
                    updateCharacter()
                    wait(0.5)
                    continue
                end
                
                local anyItemsFound = false
                
                -- Loop through selected parts
                for partName, selected in pairs(selectedItems) do
                    if not isFarming then break end
                    if selected then
                        local part = itemSpawners:FindFirstChild(partName)
                        if part and part:IsA("BasePart") then
                            local items = getSpawnedItemsFromPart(part)
                            if #items > 0 then
                                anyItemsFound = true
                                for _, itemModel in ipairs(items) do
                                    if not isFarming then break end
                                    local clickPart = getClickablePart(itemModel)
                                    if clickPart then
                                        pcall(function()
                                            pickUpItem(clickPart)
                                            totalCollected = totalCollected + 1
                                            stats.Text = "Selected: " .. updateItemCount() .. " | Collected: " .. totalCollected
                                        end)
                                    end
                                    teleportToPlot()
                                    wait(WAIT_TIME)
                                end
                            end
                        end
                    end
                end
                
                if not anyItemsFound and isFarming then
                    status.Text = "⏳ Waiting for items..."
                    status.TextColor3 = Color3.fromRGB(255, 200, 100)
                    wait(LOOP_DELAY)
                elseif isFarming then
                    status.Text = "🔄 Looping... (" .. totalCollected .. " collected)"
                    status.TextColor3 = Color3.fromRGB(150, 255, 150)
                    wait(LOOP_DELAY)
                end
            end
            
            if originalPos and humanoidRootPart then
                teleportTo(originalPos)
            end
            
            farmBtn.Text = "▶ Start Farming"
            farmBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
            farmBtn.BorderColor3 = Color3.fromRGB(0, 100, 0)
            status.Text = "⏹ Stopped"
            status.TextColor3 = Color3.fromRGB(255, 150, 150)
        end)
        coroutine.resume(farmCoroutine)
    end
    
    local function stopFarming()
        isFarming = false
        if farmCoroutine then
            coroutine.close(farmCoroutine)
            farmCoroutine = nil
        end
        farmBtn.Text = "▶ Start Farming"
        farmBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        farmBtn.BorderColor3 = Color3.fromRGB(0, 100, 0)
        status.Text = "⏹ Stopped"
        status.TextColor3 = Color3.fromRGB(255, 150, 150)
    end
    
    farmBtn.MouseButton1Click:Connect(function()
        if isFarming then stopFarming() else startFarming() end
    end)
    
    createItemSelection()
    updateItemCount()
    
    return screenGui
end

